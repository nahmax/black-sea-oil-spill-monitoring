    {
      "parameters": {
        "jsCode": "const baseEv = $items('PG.SELECT_EVENT_S1')[0].json;\nconst ch = $items('PG.GET_CHANNEL_FROM_SETTINGS1')[0].json;\n\nconst msg = $json.result ?? $json;\nconst m = msg.message || msg.channel_post || msg;\n\nconst file = m.document || m.photo?.slice(-1)[0] || null;\n\nlet chatId = String(ch.chat_id || '');\nif (!chatId.startsWith('@') && !chatId.startsWith('-100')) {\n  chatId = `-100${chatId}`;\n}\n\nreturn [{\n  json: {\n    event_id: baseEv.id,\n    channel_id: chatId,\n    message_id: m.message_id,\n    file_id: file ? file.file_id : null\n  }\n}];"
      },
