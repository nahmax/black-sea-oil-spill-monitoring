    {
      "parameters": {
        "jsCode": "const ev = $('PG.SELECT_EVENT_S1').item.json;\n\nconst lat = Number(ev.lat);\nconst lon = Number(ev.lon);\n\nif (!Number.isFinite(lat) || !Number.isFinite(lon)) {\n  throw new Error(`Нема координат в PG.SELECT_EVENT_S1: lat=${ev.lat}, lon=${ev.lon}`);\n}\n\nconst eventTimeStr = ev.event_date ?? ev.src_published_at ?? new Date().toISOString();\n\nconst current = $input.item.json ?? {};\nconst hoursBefore = Number(current.hours_before ?? 48);\nconst hoursAfter  = Number(current.hours_after  ?? 48);\nconst bboxKm = Number(current.bbox_km ?? 6); // уже 6\n\nconst t = new Date(eventTimeStr);\nconst from = new Date(t.getTime() - hoursBefore * 3600 * 1000).toISOString();\nconst to   = new Date(t.getTime() + hoursAfter  * 3600 * 1000).toISOString();\n\n// км → градусы\nconst degLat = bboxKm / 111.0;\nconst degLon = bboxKm / (111.0 * Math.cos(lat * Math.PI / 180));\n\n// Полигон AOI\nconst minLat = lat - degLat;\nconst maxLat = lat + degLat;\nconst minLon = lon - degLon;\nconst maxLon = lon + degLon;\n\nconst aoi = [\n  [minLon, minLat],\n  [maxLon, minLat],\n  [maxLon, maxLat],\n  [minLon, maxLat],\n  [minLon, minLat],\n];\n\n\nconst meters = 2 * bboxKm * 1000;      \nconst px10m  = Math.round(meters / 10); \nconst size   = Math.max(768, Math.min(2048, px10m));\n\nreturn [{\n  json: {\n    lat,\n    lon,\n    from,\n    to,\n    aoi,\n    bbox: [minLon, minLat, maxLon, maxLat], \n    timerange: `${from}/${to}`,\n    width: 1024,   \n    height: 1024\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        160
      ],
      "id": "fafad209-20f4-4e03-8b5a-ce518caf61cf",
      "name": "CODE.S1_WINDOW_AND_AOI"
    },
