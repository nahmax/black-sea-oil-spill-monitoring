    {
      "parameters": {
        "jsCode": "const ch = $items('PG.GET_CHANNEL_FROM_SETTINGS1')[0].json;\nconst post = $items('PG.GET_TG_POST1')[0].json;\n\nlet chatId = String(ch.chat_id || '');\nif (!chatId.startsWith('@') && !chatId.startsWith('-100')) {\n  chatId = `-100${chatId}`;\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    reply_to_message_id: post.message_id\n  },\n  binary: {\n    data: $items('HTTP.S1_PROCESS')[0].binary.data\n  }\n}];"
      },
