          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"input\": {\n    \"bounds\": {\n      \"geometry\": { \"type\": \"Polygon\",\n        \"coordinates\": [[[{{ $json.aoi[0][0] }},{{ $json.aoi[0][1] }}],\n                         [{{ $json.aoi[1][0] }},{{ $json.aoi[1][1] }}],\n                         [{{ $json.aoi[2][0] }},{{ $json.aoi[2][1] }}],\n                         [{{ $json.aoi[3][0] }},{{ $json.aoi[3][1] }}],\n                         [{{ $json.aoi[4][0] }},{{ $json.aoi[4][1] }}]]]\n      },\n      \"properties\": { \"crs\": \"http://www.opengis.net/def/crs/EPSG/0/4326\" }\n    },\n    \"data\": [{\n      \"type\": \"sentinel-1-grd\",\n      \"dataFilter\": {\n        \"timeRange\": { \"from\": \"{{$json.from}}\", \"to\": \"{{$json.to}}\" },\n        \"acquisitionMode\": \"IW\"\n      },\n      \"processing\": {\n        \"orthorectify\": true,\n        \"backCoeff\": \"SIGMA0_ELLIPSOID\",\n        \"reducer\": \"LATEST\"\n      }\n    }]\n  },\n  \"output\": {\n    \"width\": 1024,\n    \"height\": 1024,\n    \"responses\": [{ \"identifier\": \"default\", \"format\": { \"type\": \"image/png\" } }]\n  },\n  \"evalscript\": \"//VERSION=3\\nfunction setup(){return { input: [{ bands: [\\\"VV\\\"] }], output: [{ id: \\\"default\\\", bands: 3, sampleType: \\\"AUTO\\\" }]};}\\nfunction evaluatePixel(s){ const db = 10*Math.log10(Math.max(s.VV, 1e-8)); const v = Math.min(1, Math.max(0, (db + 25) / 25)); return [v,v,v]; }\"\n}\n",
        "options": {
          "allowUnauthorizedCerts": false,
          "response": {
            "response": {
              "fullResponse": true,
              "responseFormat": "file"
            }
          }
        }
      },
