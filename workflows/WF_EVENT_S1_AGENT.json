    {
      "parameters": {
        "method": "POST",
        "url": "https://services.sentinel-hub.com/api/v1/process",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "=application/json"
