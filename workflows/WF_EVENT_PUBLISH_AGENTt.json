      "parameters": {
        "jsCode": "const baseEv = $items('PG.GET_EVENT_FOR_VIEW')[0].json;\nconst rowCh  = $items('PG.GET_CHANNEL_FROM_SETTINGS')[0].json;\n\nconst msg = $json.result ?? $json;\nconst m = msg.message || msg.channel_post || msg;\n\nlet chatId = String(rowCh.chat_id || '');\nif (!chatId.startsWith('@') && !chatId.startsWith('-100')) {\n  chatId = `-100${chatId}`;\n}\n\nreturn [{\n  json: {\n    event_id: baseEv.id,\n    channel_id: chatId,\n    message_id: m.message_id\n  }\n}];"
