    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  e.id,\n  e.src_url,\n  e.src_title,\n  e.short_summary,\n  e.src_published_at,\n  e.event_date,\n  e.lat,\n  e.lon,\n  e.verdict,\n  e.confidence,\n  e.has_photo,\n  e.s1_date\nFROM public.events e\nWHERE e.id = {{ Number(($json.event_id || '').toString()) }};\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        464,
        80
      ],
      "id": "de762183-8345-4b01-a812-fdec1e8655f3",
      "name": "PG.GET_EVENT_FOR_VIEW",
      "credentials": {
        "postgres": {
          "id": "6wOPCgtTsfgkpNTy",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const e = $input.first().json;\n\nfunction fmtDate(iso) {\n  if (!iso) return '—';\n  const d = new Date(iso);\n  if (Number.isNaN(d.getTime())) return iso;\n  const y = d.getUTCFullYear();\n  const m = String(d.getUTCMonth()+1).padStart(2,'0');\n  const day = String(d.getUTCDate()).padStart(2,'0');\n  return `${y}-${m}-${day}`;\n}\n\nfunction fmtCoord(n) {\n  return (n === null || n === undefined) ? '—' : Number(n).toFixed(5);\n}\n\nconst evId   = e.id;\nconst url    = e.src_url || '—';\nconst title  = e.src_title || '—';\nconst pub    = fmtDate(e.src_published_at);\nconst evDate = fmtDate(e.event_date);\nconst lat    = fmtCoord(e.lat);\nconst lon    = fmtCoord(e.lon);\n\n// Вердикт\nlet verdictLine = 'Вердикт: —';\nif (e.verdict) {\n  const conf = (e.confidence !== null && e.confidence !== undefined)\n    ? ` (ймовірність ${Math.round(e.confidence * 100)}%)`\n    : '';\n  verdictLine = `Вердикт: ${e.verdict}${conf}`;\n}\n\n// Статус Sentinel-1\nlet s1Line = 'Sentinel-1: —';\nif (e.has_photo) {\n  // якщо є дата знімка — можна показати її\n  const s1Date = e.s1_date ? fmtDate(e.s1_date) : null;\n  s1Line = s1Date\n    ? `Sentinel-1: ✅ (${s1Date})`\n    : 'Sentinel-1: ✅';\n}\n\nconst lines = [\n  `Подія #${evId}`,\n  `Джерело: ${url}`,\n  `Дата: ${evDate} (публ.: ${pub})`,\n  '',\n  e.short_summary || 'Опис події наразі відсутній.',\n  '',\n  'Статус:',\n  `• Координати: ${lat},${lon}`,\n  `• ${s1Line}`,\n  `• ${verdictLine}`\n];\n\nreturn [{\n  json: {\n    event_id: evId,\n    text: lines.join('\\n')\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
