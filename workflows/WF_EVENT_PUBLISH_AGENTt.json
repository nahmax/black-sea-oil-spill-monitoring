    {
      "parameters": {
        "jsCode": "const text  = $items('CODE.RENDER_EVENT_TEXT')[0].json.text;\nconst rowMsg = $items('PG.CHECK_TG_POST')[0].json;\nconst rowCh  = $items('PG.GET_CHANNEL_FROM_SETTINGS2')[0].json;\n\nlet chatId = String(rowCh.chat_id || '');\nif (!chatId.startsWith('@') && !chatId.startsWith('-100')) {\n  chatId = `-100${chatId}`;\n}\n\nreturn [{\n  json: {\n    chat_id: chatId,\n    message_id: rowMsg.message_id,\n    text,\n    parse_mode: 'HTML'\n  }\n}];"
