        "query": "INSERT INTO public.tg_posts(event_id, channel_id, message_id)\nVALUES (\n  {{ $json.event_id }},\n  '{{ $json.channel_id }}',\n  {{ $json.message_id }}\n)\nON CONFLICT (event_id, channel_id) DO UPDATE\nSET message_id = EXCLUDED.message_id\nRETURNING event_id, channel_id, message_id;",
