    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\nconst binKeys = Object.keys(item.binary || {});\nif (!binKeys.length) {\n  throw new Error('Нема бінарних даних для LLM');\n}\nconst key = binKeys[0];\nconst src = item.binary[key];\n\n\nlet fileName = src.fileName || 's1.png';\nfileName = fileName.replace(/\\.[^.]+$/, '.png');\n\n\nitem.binary.data = {\n  ...src,\n  fileName,\n  fileExtension: 'png',\n  mimeType: 'image/png',\n};\n\n\nif (key !== 'data') {\n  delete item.binary[key];\n}\n\nreturn [item];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2528,
        336
      ],
      "id": "9d364079-e7b6-4a55-bec1-fcad8f6e44b3",
      "name": "BIN.DET.RENAME_TO_DATA"
    },
    {
      "parameters": {
        "resource": "image",
        "operation": "analyze",
        "modelId": {
          "__rl": true,
          "value": "chatgpt-4o-latest",
          "mode": "list",
          "cachedResultName": "CHATGPT-4O-LATEST"
        },
        "text": "You are a marine SAR / satellite image analyst.\n\nYou get Sentinel-1 (or similar) grayscale image over the sea.\nYour task is to detect if there is an oil spill on the sea surface.\n\nReturn STRICT JSON only, no explanations, with this shape:\n\n{\n  \"verdict\": \"spill\" | \"no_spill\" | \"uncertain\",\n  \"confidence\": 0.0-1.0,\n  \"notes\": \"short explanation in Ukrainian\"\n}",
        "inputType": "base64",
        "options": {
          "maxTokens": 200
        }
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        2752,
        336
      ],
      "id": "151185c6-d0e4-41cd-babc-fbb5a762e285",
      "name": "LLM.DET.OPENAI_VISION",
      "credentials": {
        "openAiApi": {
          "id": "PfeWoQmbI2fRBGH2",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nlet raw = item.content || item.message?.content || '';\n\nraw = String(raw || '');\n\nfunction extractJSON(str) {\n  const fence = /```json\\s*([\\s\\S]*?)\\s*```/i;\n  const m = str.match(fence);\n  if (m && m[1]) return m[1];\n  const brace = /{[\\s\\S]*}/m;\n  const m2 = str.match(brace);\n  return m2 ? m2[0] : null;\n}\n\nlet obj = {};\ntry {\n  const jsonPart = extractJSON(raw) || raw;\n  obj = JSON.parse(jsonPart);\n} catch (e) {\n  return [{\n    json: {\n      ev_id: $items('PG.DET.SELECT_EVENT')[0].json.id,\n      parse_error: String(e),\n      raw_content: raw\n    }\n  }];\n}\n\nfunction clamp01(x) {\n  const n = Number(x);\n  if (!Number.isFinite(n)) return null;\n  return Math.min(1, Math.max(0, n));\n}\n\n\nconst vRaw = String(obj.verdict || '').toLowerCase();\nlet verdict;\nif (['spill','oil_spill','positive'].includes(vRaw)) verdict = 'spill';\nelse if (['no_spill','negative','clean'].includes(vRaw)) verdict = 'skip';\nelse verdict = 'unknown';\n\nconst confidence = clamp01(obj.confidence);\n\nconst is_oil_black_sea =\n  verdict === 'spill' ? true :\n  verdict === 'skip'  ? false :\n  null;\n\nreturn [{\n  json: {\n    ev_id: $items('PG.DET.SELECT_EVENT')[0].json.id,\n    verdict,\n    confidence,\n    is_oil_black_sea,\n    notes: obj.notes || null,\n    raw_json: obj\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2960,
        336
      ],
      "id": "62cd5183-bde6-49c4-8989-394280fa4a14",
      "name": "CODE.DET.PARSE_JSON"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE public.events\nSET\n  verdict    = '{{ $json.verdict }}',      -- 'spill' | 'skip' | 'unknown'\n  confidence = {{ $json.confidence != null ? $json.confidence : 'NULL' }},\n  is_oil_black_sea = {{ $json.is_oil_black_sea === null\n                         ? 'NULL'\n                         : ($json.is_oil_black_sea ? 'TRUE' : 'FALSE') }},\n  llm_extract = COALESCE(llm_extract, '{}'::jsonb)\n                || '{{ $json.raw_json ? JSON.stringify($json.raw_json) : \"{}\" }}'::jsonb,\n  llm_version = 'gpt-4.0-mini-vision'\nWHERE id = {{ $json.ev_id }};\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
