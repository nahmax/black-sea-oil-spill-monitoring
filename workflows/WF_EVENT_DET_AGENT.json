    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO public.evidence(event_id, evidence_type, provider, url, snippet)\nVALUES (\n  {{ $node[\"CODE.DET.PARSE_JSON\"].json.ev_id }},\n  'satellite',\n  'openai:gpt-4.1-mini',\n  NULL,\n  {{ $node[\"CODE.DET.PARSE_JSON\"].json.notes\n       ? \"'\" + $node[\"CODE.DET.PARSE_JSON\"].json.notes.replace(/'/g, \"''\") + \"'\"\n       : 'NULL'\n  }}\n);",
        "options": {}
