# PostgreSQL for the event database
POSTGRES_DB=oil_spills
POSTGRES_USER=oil_spills
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=5432

# n8n runtime
N8N_HOST=localhost
N8N_HOST_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678/
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=Europe/Kyiv
TIMEZONE=Europe/Kyiv

# Workflow-level secrets used directly from env in WF_EVENT_S1_AGENT
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
